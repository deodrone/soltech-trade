VUE_APP_FIREBASE_API_KEY=your_api_key
VUE_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VUE_APP_FIREBASE_PROJECT_ID=your_project_id
VUE_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VUE_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VUE_APP_FIREBASE_APP_ID=your_app_id

VUE_APP_API_BASE_URL=http://localhost:5000

# ── Monetization ─────────────────────────────────────────────────────────────
# Your Phantom wallet address (receives SOL subscription fees + launch fees)
VUE_APP_PLATFORM_WALLET=YOUR_PHANTOM_WALLET_ADDRESS

# Jupiter Ultra Referral account pubkey (run scripts/setup-referral.js to create)
VUE_APP_REFERRAL_ACCOUNT=YOUR_REFERRAL_ACCOUNT_PUBKEY

# Integrator fee in basis points — min 50, max 255 (Jupiter keeps 20%)
VUE_APP_PLATFORM_FEE_BPS=50

# Optional: Jupiter API key for higher rate limits (get from https://portal.jup.ag)
VUE_APP_JUPITER_API_KEY=

# $SOLTECH token mint address (set after launching via your Launchpad)
VUE_APP_SOLTECH_TOKEN_MINT=YOUR_SOLTECH_TOKEN_MINT

# SOL amount charged per token launch (default 0.1)
VUE_APP_LAUNCH_FEE_SOL=0.1
